{
  "compilerOptions": {
    "target": "ESNext",
    "allowJs": true,
    "allowSyntheticDefaultImports": true,
    "module": "commonjs",
    "skipLibCheck": true,
    "esModuleInterop": true,
    "jsx": "react-jsx",
    "lib": ["es6", "dom"],
    "noImplicitAny": true,
    "sourceMap": true,
    "baseUrl": ".",
    "rootDir": ".",
    "outDir": "dist",
    "moduleResolution": "node",
    "noImplicitThis": true,
    "resolveJsonModule": true,
    "strictNullChecks": true,
    "paths": {
      /**
       * @deprecated Use @/main/* instead.
       */
      "@main/*": ["src/main/*"],
      /**
       * @deprecated Use @/shared/* instead.
       */
      "@shared/*": ["src/shared/*"],
      "@/main/*": ["src/main/*"],
      "@/shared/*": ["src/shared/*"],
      "@/*": ["src/*"],
    },
  },
}
