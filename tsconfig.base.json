{
  "compilerOptions": {
    "target": "ESNext",
    "allowJs": true,
    "allowSyntheticDefaultImports": true,
    "allowImportingTsExtensions": false,
    "isolatedModules": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "noEmit": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "jsx": "react-jsx",
    "lib": ["es6", "dom"],
    "noImplicitAny": true,
    "sourceMap": true,
    "rootDir": ".",
    "outDir": "dist",
    "noImplicitThis": true,
    "resolveJsonModule": true,
    "strictNullChecks": true,
    "paths": {
      /**
       * @deprecated Use @/main/* instead.
       */
      "@main/*": ["./src/main/*"],
      /**
       * @deprecated Use @/shared/* instead.
       */
      "@shared/*": ["./src/shared/*"],
      "@/main/*": ["./src/main/*"],
      "@/shared/*": ["./src/shared/*"],
      "@/*": ["./src/*"]
    }
  },
  "exclude": ["node_modules"]
}
